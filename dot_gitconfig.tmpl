[user]
	email = {{ .email }}
	name = {{ .name }}
	username = {{ .username }}
[core]
	autocrlf = input
[init]
	defaultBranch = main
[pull]
	rebase = false
[push]
	default = current
[alias]
	mr = push -o merge_request.create -o merge_request.remove_source_branch
	mrd = push -o merge_request.create -o merge_request.target=develop
	mrm = push -o merge_request.create -o merge_request.target=main -o merge_request.remove_source_branch
	mrs = push -o merge_request.create -o merge_request.target=stage
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[merge]
	tool = vimdiff
[mergetool]
	prompt = false
