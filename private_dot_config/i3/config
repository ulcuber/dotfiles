client.background       #ffffff

# keymap
bindsym $mod+Ctrl+Right focus output right
bindsym $mod+Ctrl+l focus output right
bindsym $mod+$alt+Right workspace next
bindsym $mod+$alt+l workspace next
bindsym $mod+n workspace next
bindsym $mod+Next workspace next
bindsym --whole-window $mod+$alt+button5 workspace next
bindsym XF86HomePage workspace next

bindsym $mod+Ctrl+Left focus output left
bindsym $mod+Ctrl+h focus output left
bindsym $mod+$alt+Left workspace prev
bindsym $mod+$alt+h workspace prev
bindsym $mod+p workspace prev
bindsym $mod+Prior workspace prev
bindsym --whole-window $mod+$alt+button4 workspace prev

bindsym $mod+Tab workspace back_and_forth

# show tiling
# bindsym $mod+x scratchpad show, floating toggle
# show floating
bindsym $mod+x scratchpad show
bindsym $mod+Shift+x move scratchpad
bindsym $mod+s sticky toggle

bindsym XF86WWW exec google-chrome-stable
bindsym XF86Tools exec google-chrome-stable https://music.yandex.ru
bindsym XF86Mail exec google-chrome-stable https://mail.yandex.ru
bindsym XF86AudioPrev exec playerctl previous
bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioPause exec playerctl play-pause
bindsym XF86AudioNext exec playerctl next

# bindsym $mod+slash exec timer toggle
# bindsym $mod+backslash exec --no-startup-id ~/.config/polybar/toggle-top
# bindsym $mod+BackSpace exec --no-startup-id ~/.config/polybar/toggle-time
# bindsym $mod+equal exec --no-startup-id ~/.config/polybar/toggle-mini
bindsym $mod+Escape exec --no-startup-id "i3lock --screen 1 --blur 1 --clock --force-clock --date-str='%A, %F' --indicator --beep --time-color='#f5f5f5' --date-color='#d0d0d0' --layout-color='#e5b566' --ring-color='#7e8d50' --inside-color='#202020' --ringwrong-color='#ac4142' --verif-color='#7dd5cf' --keylayout 0 --ignore-empty-password --radius=200 --bar-indicator --bar-color='#202020'"

# save fullscreen screenshot
bindsym $mod+Print exec "cd ~/storage/screenshots && scrot -f '%F_%H-%M-%S_screenshot.png'"
# select (-s) screenshot on freezed (-f) screen to clipboard
bindsym --release Print exec "cd ~/storage/screenshots && scrot -s -f -e 'xclip -selection clipboard -target image/png -in $f && rm $f' -f '%F_%H-%M-%S_screenshot.png'"
bindsym --release Shift+Print exec "cd ~/storage/screenshots && scrot -s -f -e 'xclip -selection clipboard -target image/png -in $f' -f '%F_%H-%M-%S_screenshot.png'"

bindsym --release $mod+i exec "cd ~/storage/screenshots && scrot -s -f -e 'xclip -selection clipboard -target image/png -in $f && rm $f' -f '%F_%H-%M-%S_screenshot.png'"
bindsym --release $mod+$alt+i exec "cd ~/storage/screenshots && scrot -f -e 'xclip -selection clipboard -target image/png -in $f && rm $f' -f '%F_%H-%M-%S_screenshot.png'"
bindsym --release $mod+Shift+i exec "cd ~/storage/screenshots && scrot -s -f -e 'xclip -selection clipboard -target image/png -in $f' -f '%F_%H-%M-%S_screenshot.png'"
bindsym --release $mod+$alt+Shift+i exec "cd ~/storage/screenshots && scrot -f -e 'xclip -selection clipboard -target image/png -in $f' -f '%F_%H-%M-%S_screenshot.png'"

exec_always i3-background

