# i3 config file (v4)
#
# Please see https://i3wm.org/docs/userguide.html for a complete reference!


# ----------------- theme -----------------

# This font is widely installed, provides lots of unicode glyphs, right-to-left
# text rendering and scalability on retina/hidpi displays (thanks to pango).
# font pango:DejaVu Sans Mono 8
font pango:ComicShannsMono Nerd Font 8

gaps outer 1
gaps inner 1
smart_gaps on

workspace_layout tabbed
default_border none
default_floating_border none
hide_edge_borders both

for_window [all] title_window_icon yes

# Colors set from ~/.Xresources
set_from_resource	$background	background
set_from_resource	$foreground	foreground
set_from_resource	$color0		color0
set_from_resource	$color1		color1
set_from_resource	$color2		color2
set_from_resource	$color3		color3
set_from_resource	$color4		color4
set_from_resource	$color5		color5
set_from_resource	$color6		color6
set_from_resource	$color7		color7
set_from_resource	$color8		color8
set_from_resource	$color9		color9
set_from_resource	$color10	color10
set_from_resource	$color11	color11
set_from_resource	$color12	color12
set_from_resource	$color13	color13
set_from_resource	$color14	color14
set_from_resource	$color15	color15

# ── Window Colors ──
# class                 border  background  text        indicator   child_border
client.focused          $color2 $color12    $foreground $color2     $color12
client.focused_inactive $color8 $color0     $foreground $color8     $color0
client.unfocused        $color8 $color0     $color8     $color8     $color0
client.urgent           $color9 $color9     $background $color9     $color9
client.placeholder      $color8 $color0     $foreground $color8     $color0
client.background       $color4

# ----------------- vars -----------------
set $mod Mod4
set $alt Mod1

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# ----------------- flat keybinds -----------------
# reload the configuration file
bindsym $mod+Shift+c reload
# restart i3 inplace (preserves your layout/session, can be used to upgrade i3)
bindsym $mod+Shift+r exec ~/.config/i3/restart
# exit i3 (logs you out of your X session)
bindsym $mod+Shift+Escape exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -B 'Yes, exit i3' 'i3-msg exit'"
bindsym $mod+Escape exec --no-startup-id "i3lock --screen 1 --blur 1 --clock --force-clock --date-str='%A, %F' --indicator --beep --time-color='#f5f5f5' --date-color='#d0d0d0' --layout-color='#e5b566' --ring-color='#7e8d50' --inside-color='#202020' --ringwrong-color='#ac4142' --verif-color='#7dd5cf' --keylayout 0 --ignore-empty-password --radius=200 --bar-indicator --bar-color='#202020'"

bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym Shift+XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +1%
bindsym Shift+Ctrl+XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +100
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym Shift+XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -1%
bindsym Shift+Ctrl+XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -100
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle

bindsym XF86AudioPrev exec playerctl previous
bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioPause exec playerctl play-pause
bindsym XF86AudioNext exec playerctl next

bindsym XF86MonBrightnessUp exec --no-startup-id brightness +10%
bindsym XF86MonBrightnessDown exec --no-startup-id brightness -10%

bindsym XF86WWW exec $BROWSER
bindsym XF86Tools exec $BROWSER https://music.yandex.ru
bindsym XF86Mail exec $BROWSER https://mail.yandex.ru

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $alt

# start a terminal
bindsym $mod+t "exec kitty"
bindsym $mod+Return "exec st"

# kill focused window
bindsym $mod+Shift+q kill
bindsym --release $mod+q exec xkill

bindsym $mod+d exec --no-startup-id ~/.config/rofi/i3-exec run
bindsym $mod+r exec --no-startup-id ~/.config/rofi/i3-exec drun
bindsym XF86Search exec --no-startup-id ~/.config/rofi/i3-exec drun

# focus windows
bindsym $mod+Left focus left
bindsym $mod+h focus left
bindsym $mod+Down focus down
bindsym $mod+j focus down
bindsym $mod+Up focus up
bindsym $mod+k focus up
bindsym $mod+Right focus right
bindsym $mod+l focus right
bindsym $alt+Tab focus right

# focus the parent container
bindsym $mod+$alt+Up focus parent
bindsym $mod+$alt+k focus parent

# focus the child container
bindsym $mod+$alt+Down focus child
bindsym $mod+$alt+j focus child

bindsym $mod+Ctrl+Right focus output right
bindsym $mod+Ctrl+l focus output right
bindsym $mod+$alt+Right workspace next
bindsym $mod+$alt+l workspace next
bindsym $mod+n workspace next
bindsym $mod+Next workspace next
bindsym --whole-window $mod+$alt+button5 workspace next
bindsym XF86HomePage workspace next

bindsym $mod+Ctrl+Left focus output left
bindsym $mod+Ctrl+h focus output left
bindsym $mod+$alt+Left workspace prev
bindsym $mod+$alt+h workspace prev
bindsym $mod+p workspace prev
bindsym $mod+Prior workspace prev
bindsym --whole-window $mod+$alt+button4 workspace prev

bindsym $mod+Tab workspace back_and_forth

# move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# alternatively, you can use the cursor keys:
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# between monitors
bindsym $mod+Ctrl+Shift+Left  move workspace to output left
bindsym $mod+Ctrl+Shift+Right move workspace to output right
bindsym $mod+Ctrl+Shift+Up move workspace to output up
bindsym $mod+Ctrl+Shift+Down move workspace to output down

bindsym $mod+Ctrl+Shift+h  move workspace to output left
bindsym $mod+Ctrl+Shift+j move workspace to output down
bindsym $mod+Ctrl+Shift+k move workspace to output up
bindsym $mod+Ctrl+Shift+l move workspace to output right

# enter fullscreen mode for the focused container
bindsym $mod+F11 fullscreen toggle
bindsym $mod+f fullscreen toggle

# change container layout (stacked, tabbed, toggle split)
bindsym $mod+Shift+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# toggle tiling / floating
bindsym $mod+Shift+space floating toggle
# change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle
bindsym $mod+Ctrl+space focus floating

# show tiling
# bindsym $mod+x scratchpad show, floating toggle
# show floating
bindsym $mod+x scratchpad show
bindsym $mod+Shift+x move scratchpad
bindsym $mod+s sticky toggle

# switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10
bindsym $mod+Shift+m exec --no-startup-id "i3-input -P 'Move window to workspace:'  -F 'move container to workspace \\"%s\\"; workspace \\"%s\\"'", mode "default"

# bindsym $mod+slash exec
# bindsym $mod+backslash exec
# bindsym $mod+BackSpace exec
# bindsym $mod+equal exec

# save fullscreen screenshot
bindsym $mod+Print exec "cd ~/storage/Pictures/screenshots && scrot -f '%F_%H-%M-%S_screenshot.png'"
# select (-s) screenshot on freezed (-f) screen to clipboard
bindsym --release Print exec "cd ~/storage/Pictures/screenshots && scrot -s -f -e 'xclip -selection clipboard -target image/png -in $f && rm $f' -f '%F_%H-%M-%S_screenshot.png'"
bindsym --release Shift+Print exec "cd ~/storage/Pictures/screenshots && scrot -s -f -e 'xclip -selection clipboard -target image/png -in $f' -f '%F_%H-%M-%S_screenshot.png'"

bindsym --release $mod+Shift+i exec "cd ~/storage/Pictures/screenshots && scrot -s -f -e 'xclip -selection clipboard -target image/png -in $f && rm $f' -f '%F_%H-%M-%S_screenshot.png'"
bindsym --release $mod+i exec "cd ~/storage/Pictures/screenshots && scrot -f -e 'xclip -selection clipboard -target image/png -in $f && rm $f' -f '%F_%H-%M-%S_screenshot.png'"
bindsym --release $mod+Shift+u exec "cd ~/storage/Pictures/screenshots && scrot -s -f -e 'xclip -selection clipboard -target image/png -in $f' -f '%F_%H-%M-%S_screenshot.png'"
bindsym --release $mod+u exec "cd ~/storage/Pictures/screenshots && scrot -f -e 'xclip -selection clipboard -target image/png -in $f' -f '%F_%H-%M-%S_screenshot.png'"

# emulate horizontal scroll
bindsym --whole-window $mod+button4 exec "xdotool click 6"
bindsym --whole-window $mod+button5 exec "xdotool click 7"
# emulate back and forward
bindsym --whole-window $mod+button3 exec "sleep 0.3 && xdotool click 8"
bindsym --whole-window $mod+button1 exec "sleep 0.3 && xdotool click 9"

# ----------------- mode keybinds ----------------- #
bindsym $mod+g mode "go"
mode "go" {
	bindsym Return mode "default"
	bindsym Escape mode "default"

	# Switch between windows on an EWMH compatible window manager.
	bindsym g exec --no-startup-id ~/.config/rofi/i3-exec window, mode "default"
	bindsym $mod+g exec --no-startup-id ~/.config/rofi/i3-exec window, mode "default"
	bindsym f exec --no-startup-id ~/.config/rofi/i3-exec filebrowser, mode "default"

	bindsym c exec --no-startup-id "i3-input -P 'Create workspace:' -F 'workspace \\"%s\\"'", mode "default"
	bindsym w exec --no-startup-id ~/.config/rofi/i3-workspace, mode "default"
}

# resize window (you can also use the mouse for that)
bindsym $mod+z mode "resize"
mode "resize" {
	bindsym $mod+z mode "default"
	bindsym Return mode "default"
	bindsym Escape mode "default"

	bindsym Left resize shrink width 10 px or 10 ppt
	bindsym Down resize grow height 10 px or 10 ppt
	bindsym Up resize shrink height 10 px or 10 ppt
	bindsym Right resize grow width 10 px or 10 ppt

	bindsym h resize shrink width 10 px or 10 ppt
	bindsym j resize grow height 10 px or 10 ppt
	bindsym k resize shrink height 10 px or 10 ppt
	bindsym l resize grow width 10 px or 10 ppt

	bindsym Shift+Left resize grow left 10 px or 10 ppt
	bindsym Shift+Down resize shrink up 10 px or 10 ppt
	bindsym Shift+Up resize grow up 10 px or 10 ppt
	bindsym Shift+Right resize shrink left 10 px or 10 ppt

	bindsym Shift+h resize grow left 10 px or 10 ppt
	bindsym Shift+j resize shrink up 10 px or 10 ppt
	bindsym Shift+k resize grow up 10 px or 10 ppt
	bindsym Shift+l resize shrink left 10 px or 10 ppt

	bindsym Ctrl+Left resize shrink width 100 px or 100 ppt
	bindsym Ctrl+Down resize grow height 100 px or 100 ppt
	bindsym Ctrl+Up resize shrink height 100 px or 100 ppt
	bindsym Ctrl+Right resize grow width 100 px or 100 ppt

	bindsym Ctrl+h resize shrink width 100 px or 100 ppt
	bindsym Ctrl+j resize grow height 100 px or 100 ppt
	bindsym Ctrl+k resize shrink height 100 px or 100 ppt
	bindsym Ctrl+l resize grow width 100 px or 100 ppt

	bindsym Ctrl+Shift+Left resize grow left 100 px or 100 ppt
	bindsym Ctrl+Shift+Down resize shrink up 100 px or 100 ppt
	bindsym Ctrl+Shift+Up resize grow up 100 px or 100 ppt
	bindsym Ctrl+Shift+Right resize shrink left 100 px or 100 ppt

	bindsym Ctrl+Shift+h resize grow left 100 px or 100 ppt
	bindsym Ctrl+Shift+j resize shrink up 100 px or 100 ppt
	bindsym Ctrl+Shift+k resize grow up 100 px or 100 ppt
	bindsym Ctrl+Shift+l resize shrink left 100 px or 100 ppt
}

bindsym $mod+m mode "move"
mode "move" {
	bindsym $mod+m mode "default"
	bindsym Return mode "default"
	bindsym Escape mode "default"

	bindsym Left move left 10 px
	bindsym Down move down 10 px
	bindsym Up move up 10 px
	bindsym Right move right 10 px

	bindsym h move left 10 px
	bindsym j move down 10 px
	bindsym k move up 10 px
	bindsym l move right 10 px

	bindsym Ctrl+Left move left 100 px
	bindsym Ctrl+Down move down 100 px
	bindsym Ctrl+Up move up 100 px
	bindsym Ctrl+Right move right 100 px

	bindsym Ctrl+h move left 100 px
	bindsym Ctrl+j move down 100 px
	bindsym Ctrl+k move up 100 px
	bindsym Ctrl+l move right 100 px

	bindsym c move position center

	# split in vertical orientation
	bindsym v split v

	# split in horizontal orientation
	bindsym Shift+v split h

	bindsym r mode "rotate"
}

bindsym $mod+o mode "open"
mode "open" {
	bindsym $mod+o mode "default"
	bindsym Escape mode "default"
	bindsym Return mode "default"

	# qwerty
	# bindsym q exec
	bindsym w exec $BROWSER, mode "default"
	bindsym e exec gvim, mode "default"
	# bindsym r exec
	# bindsym t exec

	bindsym y exec kitty yazi, mode "default"
	# bindsym u exec
	bindsym i exec kitty bash -c 'chezmoi edit ~/.config/i3/config', mode "default"
	bindsym o mode "default"
	bindsym p exec kitty bash -c 'chezmoi edit ~/.config/polybar/config.ini', mode "default"

	# asdf
	# bindsym a exec
	bindsym s exec --no-startup-id ~/.config/rofi/i3-exec ssh, mode "default"
	# bindsym d exec
	bindsym f exec firefox-bin, mode "default"
	bindsym g exec --no-startup-id ~/.config/rofi/google-search, mode "default"

	# bindsym h exec
	bindsym k exec kitty bash -c 'chezmoi edit ~/.config/kmonad/native.kbd', mode "default"
	# bindsym l exec
	# bindsym colon exec

	# zxcv
	# bindsym z exec
	# bindsym x exec
	bindsym c exec --no-startup-id xkb-switch -s us && $BROWSER https://chat.deepseek.com, mode "default"
	bindsym v exec kitty bash -c 'chezmoi edit ~/.vimrc', mode "default"
	bindsym Ctrl+v exec snote -s 12 "$(xclip -selection clipboard -o)", mode "default"

	# bindsym b exec
	bindsym n exec --no-startup-id ~/.config/rofi/snote, mode "default"
	bindsym Shift+n exec --no-startup-id ~/.config/rofi/snote -b, mode "default"
	bindsym m exec ~/bin/Telegram/Telegram, mode "default"
}

mode "rotate" {
	bindsym Return mode "default"
	bindsym Escape mode "default"

	bindsym h exec xrandr -o left, mode "default"
	bindsym l exec xrandr -o right, mode "default"
	bindsym k exec xrandr -o normal, mode "default"
	bindsym j exec xrandr -o inverted, mode "default"
}

bindsym $mod+b mode "bars"
mode "bars" {
	bindsym Return mode "default"
	bindsym Escape mode "default"

	bindsym m exec --no-startup-id polybar music, mode "default"
	bindsym t exec --no-startup-id ~/.config/polybar/toggle-top, mode "default"
	bindsym d exec --no-startup-id ~/.config/polybar/toggle-datetime, mode "default"
	bindsym s exec --no-startup-id ~/.config/polybar/toggle-free, mode "default"

	# scale,fill,tile
	bindsym b exec ~/.config/i3/background
}

# emulate mouse
bindsym $mod+colon mode "mouse"
mode "mouse" {
	bindsym Escape mode "default"

	bindsym k exec "xdotool mousemove_relative -- 0 -10"
	bindsym j exec "xdotool mousemove_relative -- 0 10"
	bindsym h exec "xdotool mousemove_relative -- -10 0"
	bindsym l exec "xdotool mousemove_relative -- 10 0"

	bindsym Ctrl+k exec "xdotool mousemove_relative -- 0 -100"
	bindsym Ctrl+j exec "xdotool mousemove_relative -- 0 100"
	bindsym Ctrl+h exec "xdotool mousemove_relative -- -100 0"
	bindsym Ctrl+l exec "xdotool mousemove_relative -- 100 0"

	bindsym d exec "xdotool click 4"
	bindsym f exec "xdotool click 5"
	bindsym --whole-window s exec "xdotool click 6"
	bindsym --whole-window g exec "xdotool click 7"
	bindsym p exec "xdotool click 8"
	bindsym n exec "xdotool click 9"

	bindsym colon exec "xdotool click 1"
	bindsym a exec "xdotool click 3"
}

bindsym $mod+c mode "change"
mode "change" {
	bindsym $mod+c mode "default"
	bindsym Escape mode "default"
	bindsym Return mode "default"

	bindsym k exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +5%
	bindsym Shift+k exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +1%
	bindsym Shift+Ctrl+k exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +100

	bindsym j exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5%
	bindsym Shift+j exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -1%
	bindsym Shift+Ctrl+j exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -100

	bindsym m exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle

	bindsym d exec --no-startup-id ~/.config/xsettingsd/set-color-scheme dark, mode "default"
	bindsym l exec --no-startup-id ~/.config/xsettingsd/set-color-scheme light, mode "default"
	bindsym b exec --no-startup-id "video2brightness --dark_threshold=40 --light_threshold=50 --mul=0.9 --add=10", mode "default"
}

bindsym $mod+v mode "vim"
mode "vim" {
	bindsym $mod+v mode "default"
	bindsym Escape mode "default"
	bindsym i mode "default"

	bindsym g mode "mc"

	bindsym --release k exec "xdotool key Up"
	bindsym --release j exec "xdotool key Down"
	bindsym --release h exec "xdotool key Left"
	bindsym --release l exec "xdotool key Right"

	bindsym --release b exec "xdotool key Ctrl+Left"
	bindsym --release w exec "xdotool key Ctrl+Right"

	bindsym --release a exec "xdotool key Right", mode "default"
	bindsym --release Shift+a exec "xdotool key --clearmodifiers End", mode "default"
	bindsym --release r exec "xdotool key Shift+Right", mode "default"
}

mode "mc" {
	bindsym Escape mode "default"
	# Left mouse is 1, middle is 2, right is 3, wheel up is 4, wheel down is 5

	bindsym --whole-window $mod+button6 exec "xdotool click 4"
	bindsym --whole-window $mod+button7 exec "xdotool click 5"

	# touchpad helpers
	bindsym j exec "xdotool click 1"
	bindsym k exec "xdotool click 3"
	bindsym l exec "xdotool click 4"
	bindsym colon exec "xdotool click 5"

	# scroll helpers
	bindsym x exec "xdotool click 4"
	bindsym c exec "xdotool click 5"

	# quick access
	bindsym --release $mod+1 exec "xdotool key 6"
	bindsym --release $mod+2 exec "xdotool key 7"
	bindsym --release $mod+3 exec "xdotool key 8"
	bindsym --release $mod+4 exec "xdotool key 9"

	# commands
	bindsym --release h mode "default", exec "xdotool key 61 && sleep 0.1 && xdotool type 'home a2' && xdotool key enter && i3-msg 'mode mc'"

	# sell all inv
	bindsym F1 exec "sleep 0.5 && xdotool getwindowfocus keydown Shift click --repeat 36 --delay 260 1 keyup Shift"
	bindsym F2 exec "sleep 0.5 && xdotool getwindowfocus keydown Shift click --repeat 36 --delay 150 1 keyup Shift"
	bindsym F3 exec "sleep 0.5 && xdotool getwindowfocus keydown Shift click --repeat 9 --delay 150 1 keyup Shift"
	bindsym F4 exec "farm"
 }

# ----------------- i3 specific autostart ----------------- #
exec_always ~/.config/i3/background

# transparency, shadows
# -b background
exec_always --no-startup-id picom -b

# dynamic themes
exec_always --no-startup-id xsettingsd

# bar {
#	 position top
#	 mode hide
#	 status_command i3status
#	 modifier $mod
# }
exec --no-startup-id ~/.config/polybar/watch
exec_always --no-startup-id "sleep 1 && ~/.config/polybar/toggle-mini"
