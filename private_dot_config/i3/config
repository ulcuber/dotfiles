# bindsym $mod+$alt+t exec --no-startup-id trans -show-translation-phonetics=n -show-languages=n -show-dictionary=n -no-ansi en:ru "$(xclip -selection clipboard -o)" | xargs -0 notify-send -i /usr/share/icons/Adwaita/256x256/legacy/dialog-question.png -a trans -u low -t 3000 -e

bindsym $mod+F1 exec "sleep 0.5 && xdotool getwindowfocus keydown Shift click --repeat 36 --delay 260 1 keyup Shift"
bindsym $mod+F2 exec "sleep 0.5 && xdotool getwindowfocus keydown Shift click --repeat 36 --delay 150 1 keyup Shift"
bindsym $mod+F3 exec "sleep 0.5 && xdotool getwindowfocus keydown Shift click --repeat 9 --delay 150 1 keyup Shift"
bindsym $mod+F4 exec "farm"

# emulate horizontal scroll
bindsym --whole-window $mod+button4 exec "xdotool click 6"
bindsym --whole-window $mod+button5 exec "xdotool click 7"
# emulate back and forward
bindsym --whole-window $mod+button3 exec "sleep 0.3 && xdotool click 8"
bindsym --whole-window $mod+button1 exec "sleep 0.3 && xdotool click 9"

# emulate mouse
bindsym $mod+colon mode "mouse"
mode "mouse" {
	bindsym Escape mode "default"

	bindsym k exec "xdotool mousemove_relative -- 0 -10"
	bindsym j exec "xdotool mousemove_relative -- 0 10"
	bindsym h exec "xdotool mousemove_relative -- -10 0"
	bindsym l exec "xdotool mousemove_relative -- 10 0"

	bindsym Ctrl+k exec "xdotool mousemove_relative -- 0 -100"
	bindsym Ctrl+j exec "xdotool mousemove_relative -- 0 100"
	bindsym Ctrl+h exec "xdotool mousemove_relative -- -100 0"
	bindsym Ctrl+l exec "xdotool mousemove_relative -- 100 0"

	bindsym d exec "xdotool click 4"
	bindsym f exec "xdotool click 5"
	bindsym --whole-window s exec "xdotool click 6"
	bindsym --whole-window g exec "xdotool click 7"
	bindsym p exec "xdotool click 8"
	bindsym n exec "xdotool click 9"

	bindsym colon exec "xdotool click 1"
	bindsym a exec "xdotool click 3"
}

mode "game" {
	bindsym Escape mode "default"

	bindsym l exec "xdotool click 4"
	bindsym colon exec "xdotool click 5"
}

mode "vim" {
	bindsym --release k exec "xdotool key Up"
	bindsym --release j exec "xdotool key Down"
	bindsym --release h exec "xdotool key Left"
	bindsym --release l exec "xdotool key Right"

	bindsym --release b exec "xdotool key Ctrl+Left"
	bindsym --release w exec "xdotool key Ctrl+Right"

	bindsym --release a exec "xdotool key Right", mode "default"
	bindsym --release Shift+a exec "xdotool key --clearmodifiers End", mode "default"
	bindsym --release r exec "xdotool key Shift+Right", mode "default"

	bindsym Escape mode "default"
	bindsym $mod+v mode "default"
	bindsym i mode "default"
}
bindsym $mod+v mode "vim"

# transparency, shadows
