#!/sbin/openrc-run

USER=victor

rc_need="bluetoothd"
supervisor="supervise-daemon"

command_user="${USER}"

command="/home/${USER}/.local/bin/kmonad"
command_args="/home/${USER}/.config/kmonad/bluetooth-3.0-keyboard.kbd"
pidfile="/run/kmonad-bluetooth-3.0-keyboard.pid"
output_log="/var/log/${USER}/kmonad-bluetooth-3.0-keyboard.log"
error_log="/var/log/${USER}/kmonad-bluetooth-3.0-keyboard.err"

start_pre() {
    max_wait=5
    while [ ! -e "/dev/input/by-name/bluetooth-3.0-keyboard" ] && [ $max_wait -gt 0 ]; do
        sleep 0.5
        max_wait=$((max_wait - 1))
    done
    [ -e "/dev/input/by-name/bluetooth-3.0-keyboard" ] || return 1
    sleep 1
}
