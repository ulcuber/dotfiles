[settings]
screenchange-reload = true
pseudo-transparency = false

[colors]
# Alpha=CC + Raisin Black
background = #CC202020
background-alt = ${xrdb:selection_background}
foreground = ${xrdb:foreground}
primary = ${xrdb:color2}
secondary = ${xrdb:color6}
alert = ${xrdb:color1}
disabled = ${xrdb:selection_background}

[bar/base]
monitor = ${env:MONITOR:}

width = 100%
height = 20pt

; border-left-size = 4pt
; border-right-size = 4pt
; border-bottom-size = 4pt

radius = 18
radius-top-left = 0.0
radius-top-right = 0.0

; dpi = 96

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 4pt

module-margin = 1

separator = |
separator-foreground = ${colors.disabled}

font-0 = Iosevka Term:style=Regular
font-1 = Noto Color Emoji:scale=8

cursor-click = pointer
cursor-scroll = ns-resize

; enable-ipc = true

[bar/top]
inherit = bar/base

border-color = #00000000

tray-position = right
tray-detached = false
tray-padding = 1

vm-restack = i3
; override-redirect = true

enable-ipc = true

modules-left = rofi minify i3
modules-right = github wlan filesystem cpu cpu_temp ssd_temp memory xkeyboard pulseaudio battery real-battery xbacklight datetime

[bar/time]
inherit = bar/free

offset-x = 50%:+260pt
width = 360pt

radius-top-left = 0
radius-top-right = 0
radius-bottom-left = 18
radius-bottom-right = 18

modules-center = date time-utc time-moscow

[bar/free]
inherit = bar/base

font-0 = Iosevka Term:style=Regular:14;1

override-redirect = true
height = 14pt
line-size = 1pt
border = 0

[bar/i3]
inherit = bar/free

width = 200pt
# minus half of width
offset-x = 50%:-100pt
height = 14pt

radius-top-left = 0
radius-top-right = 0
radius-bottom-left = 18
radius-bottom-right = 18

modules-left = output
modules-center = i3
modules-right = rofi

[bar/i3-hdmi]
inherit = bar/free

width = 300pt
offset-x = 100%:-300pt

height = 24pt

line-size = 6pt

radius-top-left = 0
radius-top-right = 0
radius-bottom-left = 18
radius-bottom-right = 0

modules-left = output
modules-center = i3

[bar/i3-mode]
inherit = bar/free

offset-x = 50%:-420pt
width = 230pt

radius-top-left = 0
radius-top-right = 0
radius-bottom-left = 18
radius-bottom-right = 18

modules-center = i3-mode

[bar/mini]
inherit = bar/free

#font-0 = Press Start 2P:style=Bold:size=14;4
font-0 = Iosevka Term:style=Bold:size=22;4

width = 62pt
height = 24pt
offset-x = 100%:-62pt
radius-bottom-right = 0.0

modules-right = time

[bar/off-bar]
inherit = bar/free

width = 18pt
height = 20pt

radius-bottom-right = 14

modules-left = off

[bar/sound]
inherit = bar/free

#font-0 = Noto Sans Mono:style=Regular:8;1
font-0 = Iosevka Term Heavy:style=Bold:size=14;1
font-1 = Noto Color Emoji:scale=9

# offset-x = 2pt
# offset-y = 2pt
height = 24pt
width = 40pt

#background = #CCFFFFFF
label-empty-background = #00FFFFFF
foreground = ${colors.primary}
separator =

#radius-top-left = 8
#radius-top-right = 8
#radius-bottom-left = 8
#radius-bottom-right = 8

radius-top-left = 0
radius-top-right = 0
radius-bottom-left = 0
radius-bottom-right = 18

modules-left = pulseaudio

[bar/battery]
inherit = bar/free

font-0 = Iosevka Term Heavy:style=Regular:14;1
font-1 = Noto Color Emoji:scale=8;4

offset-y = 98.5%

width = 50pt
height = 1.6%
line-size = 0

radius-top-left = 0
radius-top-right = 18
radius-bottom-left = 0
radius-bottom-right = 0

label-empty-background = #00FFFFFF
separator =

modules-left = real-battery-mini

[bar/indicator]
override-redirect = true

#font-0 = Press Start 2P:style=Bold:size=16;4
font-0 = Iosevka Term Thin:style=Bold:size=20;4
font-1 = Noto Color Emoji:scale=5;4

background = ${colors.background}

padding = 0
separator =

offset-x = 100%:-120pt

width = 120pt
height = 28pt
line-size = 0

radius-top-left = 18
radius-top-right = 0
radius-bottom-left = 18
radius-bottom-right = 0

[bar/music-trigger-bar]
inherit = bar/indicator

width = 2%
offset-x = 98%
offset-y = 17%

radius-top-left = 18
radius-top-right = 0
radius-bottom-left = 18
radius-bottom-right = 0

modules-center = music-trigger

[bar/music-bar]
inherit = bar/free

font-0 = Iosevka Term:style=Bold:size=12;1
font-1 = Noto Color Emoji:style=Bold:scale=7;2
font-2 = Noto Sans CJK JP:style=Bold:size=12;1
font-3 = Wuncon Siji:size=12;1

line-size = 0
padding = 0

width = 60%
offset-x = 35%
offset-y = 100%:-12pt

radius-top-left = 18
radius-top-right = 18
radius-bottom-left = 0
radius-bottom-right = 0

modules-center = music

[bar/process-trigger-bar]
inherit = bar/indicator

width = 2%
offset-x = 98%
offset-y = 21%

radius-top-left = 18
radius-top-right = 0
radius-bottom-left = 18
radius-bottom-right = 0

modules-center = process-trigger

[bar/process-bar]
inherit = bar/indicator

font-0 = Iosevka Term Thin:style=Bold:size=14;4
font-1 = Noto Color Emoji:scale=5;4
font-2 = Noto Sans CJK JP:style=Bold:size=14;4
font-3 = Wuncon Siji:size=14;4

width = 25%
offset-x = 75%
offset-y = 21%

radius-top-left = 18
radius-top-right = 0
radius-bottom-left = 18
radius-bottom-right = 0

modules-center = process

[bar/heat]
inherit = bar/indicator
offset-y = 28%
modules-left = cpu-temp-mini

[bar/memory]
inherit = bar/indicator
offset-y = 32%
modules-left = mem-free-mini

[module/rofi]
type = custom/text
content= "ūüĒć"
content-padding = 1
click-left = "~/.config/polybar/rofi-launcher '{cmd}'"
click-right = "rofi -show window -theme ~/.config/rofi/themes/afterglow-mouse.rasi -run-command i3-msg exec '{cmd}'"

[module/minify]
type = custom/text
content = "‚ú®"
click-left = "~/.config/polybar/toggle-mini"

[module/maximize]
type = custom/text
content = "‚ú®"
click-left = "~/.config/polybar/toggle-top"

[module/xwindow]
type = internal/xwindow
label = %title%

[module/filesystem]
type = internal/fs
interval = 120

mount-0 = /

label-mounted = %free%

label-unmounted = %mountpoint% not mounted
label-unmounted-foreground = ${colors.disabled}

label-warn = ! %free%

[module/pulseaudio]
type = internal/pulseaudio

bar-volume-width = 150
bar-volume-empty = ‚ĖĎ
bar-volume-fill = ‚Ėą
bar-volume-indicator = |

format-volume-prefix = "ūüéĶ"
format-volume-prefix-foreground = ${colors.primary}
format-volume = <label-volume>
#format-volume = <bar-volume>
format-volume-foreground = ${colors.primary}

#label-volume = %percentage% (%decibels%)
label-volume = %percentage%
label-volume-foreground = ${colors.primary}

label-muted = "ūüĒá"
label-muted-foreground = ${colors.disabled}

[module/xkeyboard]
type = internal/xkeyboard
blacklist-0 = num lock

label-layout = %layout%
label-layout-foreground = ${colors.primary}

label-indicator-padding = 0
label-indicator-margin = 0
label-indicator-foreground = ${colors.background}
label-indicator-background = ${colors.secondary}

[module/memory]
type = internal/memory
interval = 10
format-prefix = ""
format-prefix-foreground = ${colors.primary}
label = %free%

[module/cpu]
type = internal/cpu
interval = 10
format-prefix = ""
format-prefix-foreground = ${colors.primary}
label = %percentage:2%%

[network-base]
type = internal/network
interval = 10
format-connected = <ramp-signal><label-connected>
format-disconnected = <label-disconnected>
label-disconnected = %{F#7e8d50}%ifname%%{F#ac4142} disconnected
ramp-signal-0 = ūüėĪ
ramp-signal-1 = ūüė†
ramp-signal-2 = ūüėí
ramp-signal-3 = ūüėä
ramp-signal-4 = ūüėÉ
ramp-signal-5 = ūüĎć

[module/wlan]
inherit = network-base
interface-type = wireless
label-connected = %signal% %{F#7e8d50}%essid%%{F-} %local_ip%

[module/date]
type = internal/date
format = <label>
label = %date%
label-foreground = ${colors.primary}
date = %a %Y-%m-%d
time =
interval = 3600

[module/datetime]
type = internal/date
format = <label>
label = %date% %time%
label-foreground = ${colors.primary}
date = %a %Y-%m-%d
time = %H:%M
interval = 60

[module/time]
type = internal/date
format = <label>
label = %time%
label-foreground = ${colors.primary}
time = %H:%M
interval = 60

[module/time-utc]
type = custom/script
exec = TZ=Etc/UTC date +"UTC: %H:%M"
interval = 60

[module/time-moscow]
type = custom/script
exec = TZ=Europe/Moscow date +"MSC: %H:%M"
interval = 60

[module/battery]
type = internal/battery
low-at = 30
time-format = %H:%M
format-charging = ūüĒĆ<label-charging>
format-discharging = <ramp-capacity><label-discharging>
poll-interval = 60
label-charging = %percentage%%
label-discharging = %percentage%% %consumption%W
label-full = %percentage%%
label-low = %percentage%% %consumption%W
ramp-capacity-0 = ūüĒč
ramp-capacity-1 = ūüĒč
ramp-capacity-2 = ūüĒč
ramp-capacity-3 = ūüĒč
ramp-capacity-4 = ūü™ę

[module/music]
type = custom/script
exec = ~/.config/polybar/music
tail = true
format-padding = 1
click-left = kill -CONT %pid%
click-right = kill -USR1 %pid%
click-middle = sleep 0.5 && pkill -f -x 'polybar music-bar' && polybar music-trigger-bar
double-click-left = kill -USR2 %pid%
scroll-up = pactl set-sink-volume @DEFAULT_SINK@ +1%
scroll-down = pactl set-sink-volume @DEFAULT_SINK@ -1%

[module/music-trigger]
type = custom/text
content = "ūüéĶ"
click-left = pkill -f -x 'polybar music-trigger-bar' && sleep 0.5 && polybar music-bar

[module/process]
type = custom/script
exec = watch-process
tail = true
format-prefix = "‚öôÔłŹ"
format-padding = 1
click-left = sleep 0.5 && kill %pid%
click-right = pkill -f -x 'polybar process-bar' && polybar process-trigger-bar

[module/process-trigger]
type = custom/text
content = "‚öôÔłŹ"
click-left = pkill -f -x 'polybar process-trigger-bar' && sleep 0.5 && polybar process-bar

[module/real-battery]
type = custom/script
exec = echo "($(battery))"
interval = 60

[module/real-battery-mini]
type = custom/script
exec = bash ~/git-repos/own/bash/bash-scripts/bin/battery-real-percent monitor
interval = 60
click-left = "pkill -f -x 'polybar battery'"

[module/cpu-temp-mini]
type = custom/script
exec = bash -c '~/git-repos/own/bash/bash-scripts/bin/cpu-temp {{ .temperature_sensor }}'
interval = 3
click-left = "pkill -f -x 'polybar heat'"

[module/mem-free-mini]
type = custom/script
exec = bash ~/git-repos/own/bash/bash-scripts/bin/mem-free
interval = 3
click-left = "pkill -f -x 'polybar memory'"

[module/output]
type = custom/script
exec-if = "[[ $(polybar -m | wc -l) > 1 ]]"
exec = bash ~/git-repos/own/bash/bash-scripts/bin/i3-output
tail = true
format-padding = 1
click-left = i3-msg -t command 'focus output left'
click-right = i3-msg -t command 'focus output right'
scroll-up = i3-msg -t command 'focus output left'
scroll-down = i3-msg -t command 'focus output right'

[module/off]
type = custom/text
content = ūüĒí
click-left = "~/.config/polybar/toggle-mini off; i3-nagbar -t warning -m 'Do you really want to exit i3? This will end your X session.' -B 'Yes, exit i3' 'i3-msg exit'"

[module/xbacklight]
type = internal/xbacklight
label = ūüĒÜ%percentage%%

[module/github]
type = internal/github
token = ${env:GITHUB_ACCESS_TOKEN}
user = ${env:GITHUB_USER}
interval = 300
label = %{A1:xdg-open https\\://github.com/notifications:}github: %notifications%%{A}
label-offline = ""
empty-notifications = false

[module/i3-mode]
type = internal/i3
format = m: <label-mode>

[module/i3]
type = internal/i3

index-sort = true

format = <label-state> <label-mode>

label-focused = %name%
label-focused-background = ${colors.primary}
label-focused-padding = 1

label-unfocused = %name%
label-unfocused-padding = 1

label-visible = %name%
label-visible-underline = ${colors.secondary}
label-visible-padding = 1

label-urgent = %name%
label-urgent-background = ${colors.alert}
label-urgent-padding = 1

[module/i3-pinned]
inherit = module/i3

pin-workspaces = true
show-urgent = true

# pch_cannonlake
[module/cpu_temp]
type = internal/temperature
thermal-zone = 5
interval = 5
label = %temperature-c%
warn-temperature = 60
format-warn = <ramp><label-warn>
ramp-0 = ""
ramp-1 = !
ramp-2 = ūüĒ•

# acpitz-acpi-0
[module/ssd_temp]
type = internal/temperature
thermal-zone = 0
interval = 5
label = %temperature-c%
warn-temperature = 60
format-warn = <ramp><label-warn>
ramp-0 = ""
ramp-1 = !
ramp-2 = ūüĒ•

[module/weather]
type = custom/script
exec = "polybar-msg action '#weather_ipc.hook.0'"
interval = 1000
label =

[module/weather_ipc]
type = custom/ipc
hook-0 = "curl -fsS --compressed 'wttr.in/ulyanovsk?format=%t+(%f)+%x%c%C+(%p)+%h+%w+%P+%m%M\\n'"
initial = 0

; vim:ft=dosini
