/* vim: set filetype=rasi : */
* {
    /* ── Elysia's Pastel Dream Palette ── */
    background-color: rgba(255, 235, 245, 0.92);    /* Soft pink cream */
    text-color:      #5a3d5c;                      /* Warm purple-brown */
    accent-color:    #ff7b9c;                      /* Elysia pink */
    accent2-color:   #ffb8d0;                     /* Light pink */
    accent3-color:   #e8c97a;                     /* Gold accent */

    /* ── Font ── */
    font: "ComicShannsMono Nerd Font 14";

    /* ── Cute spacing ── */
    spacing: 12;
    padding: 16;
}

/* ── Main Window ── */
window {
    location: center;
    anchor: center;
    width: 20em;                                   /* Responsive width */
    border-radius: 30px;
    border: 3px;
    border-color: @accent2-color;
    background-color: @background-color;
    padding: 20;
    children: [ inputbar, message, listview ];
}

/* ── Input Bar ── */
inputbar {
    children: [ prompt, entry ];
    background-color: rgba(255, 255, 255, 0.5);
    border-radius: 20px;
    border: 2px;
    border-color: @accent2-color;
    spacing: 8;
    padding: 10 16;
    margin: 0 0 12 0;
}

prompt {
    text-color: @accent-color;
    font: "ComicShanns Nerd Font 22";
    padding: 0 4;
}

entry {
    text-color: @text-color;
    background-color: transparent;
    placeholder-color: rgba(90, 61, 92, 0.3);
    expand: true;
    padding: 4 8;
    font: "ComicShanns Nerd Font 14";
}

/* ── Message ── */
message {
    background-color: transparent;                 /* Critical for message */
    border: none;
    padding: 4 8;
    margin: 4 0;
    text-color: @accent3-color;
    font: "ComicShanns Nerd Font 12";
}

/* ── List View ── */
listview {
    background-color: transparent;
    border: none;
    spacing: 6;
    padding: 8 0;
    scrollbar: false;
    dynamic: true;
    layout: vertical;
    lines: {{ .rofi_lines }};
}

/* ── Each Workspace Entry ── */
element {
    background-color: rgba(255, 255, 255, 0.3);
    text-color: @text-color;
    border: 2px;
    border-color: transparent;
    border-radius: 18px;
    padding: 10 18;
    margin: 2 0;
    font: "ComicShanns Nerd Font 14";
    children: [ element-icon, element-text ];
}

element-icon {
  size: 1em;
  background-color: transparent;
}

element-text {
    text-color: inherit;
    background-color: transparent;
}

element normal {
    background-color: rgba(255, 255, 255, 0.2);
}

element selected {
    background-color: @accent2-color;
    text-color: #ffffff;
    border: 2px;
    border-color: @accent-color;
    border-radius: 18px;
    padding: 10 18;
    font: "ComicShanns Nerd Font 15";
}

element selected element-text {
    background-color: transparent;
    font-weight: bold;
}

/* ── Scrollbar (if needed) ── */
scrollbar {
    handle-width: 4px;
    handle-color: @accent2-color;
    background-color: transparent;
    border-radius: 10px;
}
