function! ApplyColorScheme()
    let scheme = trim(system('~/.config/xsettingsd/get-color-scheme'))
    echo scheme

    if scheme == "dark"
        colorscheme codedark
    else
        colorscheme one
    endif
    call timer_start(500, {-> SetTransparency()})
endfunction
autocmd VimEnter * call ApplyColorScheme()

