function! OpenFileWithFzf(input, ...)
  let opts = a:0 > 0 ? a:1 : {}
  let use_git = get(opts, 'use_git', 0)
  let input = trim(a:input)

  " Match: file.php:45 or file.php(45)
  let match = matchlist(input, '^\(.*[^:)]\)[:(]\(\d\+\)[):]\?$')

  if !empty(match) && !empty(match[1]) && !empty(match[2])
    let filename = match[1]
    let line_num = match[2]
  else
    let filename = input
    let line_num = ''
  endif

  let processed_query = ProcessInputForFzf(filename)

  if use_git
    call fzf#vim#gitfiles('', {
          \ 'options': ['--query', processed_query],
          \ 'sink': { path -> s:HandleFileOpen(line_num, path) }
          \ })
  else
    call fzf#vim#files('', {
          \ 'options': ['--query', processed_query],
          \ 'sink': { path -> s:HandleFileOpen(line_num, path) }
          \ })
  endif
endfunction

function! ProcessInputForFzf(input)
  let input = a:input

  " PHP use statements
  if input =~ '^\s*use\s\+\S\+;\s*$'
    return substitute(input,
          \ '^\s*use\s\+\(\S\+\);\s*$',
          \ '\=join(split(submatch(1), "\\"), "/").".php"',
          \ '')

  " Laravel view calls
  elseif input =~ 'view.*[''"]\S\+[''"]'
    return substitute(input,
          \ '^.*view.*[''"]\(\S\+\)[''"].*$',
          \ '\=substitute(submatch(1), "\\\.", "/", "g").".blade.php"',
          \ '')

  " PHP namespace paths
  elseif input =~ '\\'
    return substitute(input, '(\\)*', '/', 'g') . '.php'

  " Raw text - convert path separators for better fuzzy matching
  else
    return substitute(input, '/\|\\', ' ', 'g')
  endif
endfunction

function! s:HandleFileOpen(line_num, selected)
  execute 'tabnew ' . fnameescape(a:selected)
  if !empty(a:line_num)
    execute a:line_num
    normal! zz

    let s:jump_highlight_id = matchadd('JumpLine', '\%'.line('.').'l')
  endif
endfunction

function! ProcessStackTraceAndOpenFiles() range
    let lines = getline(a:firstline, a:lastline)

    for i in range(len(lines) - 1, 0, -1)
        let line = lines[i]
        if (line =~# 'app/' || line =~# 'tests/') && line !~# 'Middleware'
            let input = matchstr(line, '\(app/\|tests/\).*$')

            if !empty(input)
                " Match: file.php:45 or file.php(45)
                let match = matchlist(input, '^\(.*[^:)]\)[:(]\(\d\+\)[):]\?$')

                if !empty(match) && !empty(match[1]) && !empty(match[2])
                  let filename = match[1]
                  let line_num = match[2]
                else
                  let filename = input
                  let line_num = ''
                endif
                call s:HandleFileOpen(line_num, filename)
            endif
        endif
    endfor
endfunction

