function! SmartSpeakLine()
    let current_ft = &filetype

    if current_ft == 'php' || current_ft == 'php.*'
        call SpeakPHPCode()
    elseif current_ft == 'python' || current_ft == 'python.*'
        " Could add Python-specific handling here
        call SpeakCurrentLine()
    elseif current_ft == 'javascript' || current_ft == 'typescript' || current_ft == 'js' || current_ft == 'ts'
        " Could add JS/TS handling here
        call SpeakCurrentLine()
    else
        " Default for other filetypes
        call SpeakCurrentLine()
    endif
endfunction

function! SpeakPHPCode()
    normal! "ayy
    let line_text = join(split(@a, "\n"), " ")
    let escaped_line = shellescape(line_text)

    let command = 'echo '. escaped_line .' | '. g:php_tts_bin .' --model='. g:piper_voice .' | aplay -r 22050 -f S16_LE -t raw - 2>/dev/null &'

    echo command
    call system(command)
    set lazyredraw
    redraw!
endfunction

function! AskDeepSeek(prompt)
    let api_url = "https://api.deepseek.com/v1/chat/completions"
    if ! exists('$DEEPSEEK_API_TOKEN')
        return 'Missing $DEEPSEEK_API_TOKEN'
    endif

    let api_key = $DEEPSEEK_API_TOKEN
    if empty(api_key)
        return '$DEEPSEEK_API_TOKEN is empty'
    endif

    let payload = json_encode({
        \ "model": "deepseek-chat",
        \ "messages": [{"role": "user", "content": a:prompt}],
        \ "max_tokens": 100
        \ })

    let cmd = 'curl -s -X POST ' . api_url .
        \ ' -H "Content-Type: application/json"' .
        \ ' -H "Authorization: Bearer ' . api_key . '"' .
        \ ' -d ' . shellescape(payload)
    let response = system(cmd)

    let json_response = {}
    try
        let json_response = json_decode(response)
    catch
        return response
    endtry

    if has_key(json_response, 'choices') && len(json_response.choices) > 0
        let ai_response = json_response.choices[0].message.content
        return ai_response
    endif

    return response
endfunction

