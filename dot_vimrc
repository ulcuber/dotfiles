    file [Chat Log]
    let g:chat_log_buf = bufnr('%')
    call setbufline(g:chat_log_buf, 1, 'Messages')

    execute 'resize ' . float2nr(&lines * 0.8)

    below new
    setlocal buftype=nofile
    setlocal bufhidden=hide
    setlocal noswapfile
    setlocal filetype=text
    setlocal nonumber
