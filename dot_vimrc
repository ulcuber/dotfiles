function! s:AutoToggleUI()
    let min_width = 120  " Minimum width to show minimap and line numbers

    " Check if current buffer is a terminal window
    let is_terminal = &buftype == 'terminal'

    if winwidth(0) >= min_width
        if !exists('g:minimap_loaded') || g:minimap_loaded == 0
            if exists(':Minimap') == 2
                Minimap
                let g:minimap_loaded = 1
            endif
        endif

        if !is_terminal
            set number
        endif
    else
        if exists('g:minimap_loaded') && g:minimap_loaded == 1
            if exists(':MinimapClose') == 2
                MinimapClose
                let g:minimap_loaded = 0
            endif
        endif

        if !is_terminal
            set nonumber
        endif
    endif
endfunction

