    file [Chat Input]
    let g:chat_input_buf = bufnr('%')

    execute 'resize ' . float2nr(&lines * 0.2)

    nnoremap <buffer> <CR> :call SendMessageFromInput()<CR>

    wincmd j
endfunction

function! SendMessageFromInput()
    let message = join(getbufline(g:chat_input_buf, 1, '$'), "\n")
    if empty(message)
        return
    endif

    let user = empty('$USER') ? 'You' : $USER
    call SendMessage(user, message)

    call deletebufline(g:chat_input_buf, 1, '$')

    let answer = AskDeepSeek(message)
    call SendMessage('DeepSeek', answer)
endfunction

function! SendMessage(username, message)
    let timestamp = strftime('%H:%M:%S')

    let formatted_message = '[' . timestamp . '] ' . a:username . ": " . a:message
    call appendbufline(g:chat_log_buf, '$', split(formatted_message, "\n"))

    let log_win = bufwinnr(g:chat_log_buf)
    if log_win != -1
        execute log_win . 'wincmd w'
        normal! G
        wincmd p
    endif
endfunction

command! Chat call StartChat()

